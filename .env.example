# Supabase configuration — copy to .env.local and fill in.
# Public (safe for the browser):
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<publishable-or-anon-key>

# Public marketing/landing site the login page links back to.
# Optional — defaults to https://thesocceriqlab.com/ if unset.
NEXT_PUBLIC_LANDING_URL=https://thesocceriqlab.com/

# Native app store listing URLs shown on the login/signup page.
# Leave BLANK until the listings are published — the badges render as a
# non-clickable "Coming soon" state while empty, and become live links once set.
NEXT_PUBLIC_PLAY_STORE_URL=
NEXT_PUBLIC_APP_STORE_URL=

# Server-only secret (used by route handlers / admin tasks — never commit):
SUPABASE_SERVICE_ROLE_KEY=<service-role-or-secret-key>

# Resend — post-lesson feedback emails (server-only)
RESEND_API_KEY=your_resend_key_here
# Must be an address on a Resend-VERIFIED domain to deliver to arbitrary recipients
# (onboarding@resend.dev only delivers to the Resend account owner in test mode).
RESEND_FROM_EMAIL=you@your-verified-domain.com
FEEDBACK_TO_EMAIL=marcus@thesocceriqlab.com
