# Supabase configuration — copy to .env.local and fill in.
# Public (safe for the browser):
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<publishable-or-anon-key>

# Public marketing/landing site the login page links back to.
# Optional — defaults to https://thesocceriqlab.com/ if unset.
NEXT_PUBLIC_LANDING_URL=https://thesocceriqlab.com/

# Server-only secret (used by route handlers / admin tasks — never commit):
SUPABASE_SERVICE_ROLE_KEY=<service-role-or-secret-key>
